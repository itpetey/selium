package messaging.echo.v1;

schema EchoRequest {
  correlation_id: string;
  msg: string;
}

schema EchoResponse {
  correlation_id: string;
  msg: string;
  responder: string;
}

event echo.requested(EchoRequest) {
  partitions: 4;
  retention: "12h";
  delivery: at_least_once;
  replay: enabled;
}

event echo.responded(EchoResponse) {
  partitions: 4;
  retention: "12h";
  delivery: at_least_once;
  replay: enabled;
}

service echo(EchoRequest) -> EchoResponse;
