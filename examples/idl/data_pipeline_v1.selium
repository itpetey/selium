package analytics.pipeline.v1;

schema NumberFrame {
  source: string;
  value: i64;
  ts_ms: u64;
}

schema NumberSummary {
  source: string;
  value: i64;
  doubled: i64;
  plus_five: i64;
  is_even: bool;
}

event ingest.numbers(NumberFrame) {
  partitions: 12;
  retention: "24h";
  delivery: at_least_once;
  replay: enabled;
}

event transform.summaries(NumberSummary) {
  partitions: 12;
  retention: "24h";
  delivery: at_least_once;
  replay: enabled;
}
