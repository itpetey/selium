package network.http.upload.v1;

schema UploadRequest {
  file_name: string;
  content_type: string;
}

schema UploadReceipt {
  file_name: string;
  bytes_received: u64;
}

service upload(UploadRequest) -> UploadReceipt {
  protocol: http;
  method: POST;
  path: "/upload/{file_name}";
  request-header: content_type = "content-type";
  request-body: stream<bytes>;
  response-body: buffered<UploadReceipt>;
}
