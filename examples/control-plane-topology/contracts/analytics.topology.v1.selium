package analytics.topology.v1;

schema Frame {
  source: string;
  seq: u32;
}

schema EnrichedFrame {
  source: string;
  seq: u32;
  stage: string;
}

event ingest.frames(Frame) {
  partitions: 8;
  retention: "6h";
  delivery: at_least_once;
  replay: enabled;
}

event process.enriched(EnrichedFrame) {
  partitions: 8;
  retention: "6h";
  delivery: at_least_once;
  replay: enabled;
}
