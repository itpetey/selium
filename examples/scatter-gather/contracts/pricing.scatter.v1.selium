package pricing.scatter.v1;

schema QuoteRequest {
  request_id: u32;
  quantity: u32;
}

schema QuoteResponse {
  request_id: u32;
  worker: string;
  total_cents: u32;
}

service quote(QuoteRequest) -> QuoteResponse;

event pricing.quote_results(QuoteResponse) {
  partitions: 8;
  retention: "2h";
  delivery: at_least_once;
  replay: enabled;
}
