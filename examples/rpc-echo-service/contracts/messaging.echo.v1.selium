package messaging.echo.v1;

schema EchoRequest {
  correlation_id: u32;
  body: string;
}

schema EchoResponse {
  correlation_id: u32;
  echoed: string;
}

event echo.requested(EchoRequest) {
  partitions: 4;
  retention: "1h";
  delivery: at_least_once;
  replay: enabled;
}

event echo.responded(EchoResponse) {
  partitions: 4;
  retention: "1h";
  delivery: at_least_once;
  replay: enabled;
}

service echo(EchoRequest) -> EchoResponse;
