package stateful.counter.v1;

schema CounterDelta {
  seq: u32;
  amount: u32;
}

schema CounterCheckpoint {
  last_seq: u32;
  running_total: u32;
  mode: string;
}

event counter.deltas(CounterDelta) {
  partitions: 4;
  retention: "4h";
  delivery: at_least_once;
  replay: enabled;
}

event counter.checkpoints(CounterCheckpoint) {
  partitions: 4;
  retention: "4h";
  delivery: at_least_once;
  replay: enabled;
}
